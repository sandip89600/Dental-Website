<%- include ("navbar.ejs")%>
<div class="main-panel">
    <div class="content">
        <div class="container-fluid">
            <h4 class="page-title">Add New Doctor</h4>
            <div class="card">
                <div class="card-body">
                    <form action="/admin/save-doctor" method="post" enctype="multipart/form-data">
                        <div class="form-group">
                            <label for="doctor_name">Doctor Name</label>
                            <input type="text" class="form-control" name="d_name" placeholder="Enter Doctor Name" required>
                        </div>
                        <div class="form-group">
                            <label for="doctor_role">Specialization / Role</label>
                            <input type="text" class="form-control" name="d_role" placeholder="e.g. Implant Surgeon" required>
                        </div>
                        <div class="form-group">
                            <label for="doctor_image">Doctor Image</label>
                            <input type="file" class="form-control-file" name="d_image" required>
                        </div>
                        <div class="row">
                            <div class="col-md-3 form-group"><label>Twitter</label><input type="text" class="form-control" name="d_insta" placeholder="URL"></div>
                            <div class="col-md-3 form-group"><label>Facebook</label><input type="text" class="form-control" name="d_face" placeholder="URL"></div>
                            <div class="col-md-3 form-group"><label>LinkedIn</label><input type="text" class="form-control" name="d_twt" placeholder="URL"></div>
                            <div class="col-md-3 form-group"><label>Instagram</label><input type="text" class="form-control" name="d_li" placeholder="URL"></div>
                        </div>
                        <div class="card-action">
                            <button type="submit" class="btn btn-success">Add Doctor</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<%- include ("footer.ejs")%>


